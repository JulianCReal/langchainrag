# Copy this file to .env and fill in your keys
# cp .env.example .env

# Groq API key — https://console.groq.com (free, no credit card)
GROQ_API_KEY=gsk_...

# Pinecone API key — https://app.pinecone.io (free, no credit card)
PINECONE_API_KEY=pcsk_...

# Name of the Pinecone index (will be created automatically)
PINECONE_INDEX_NAME=langchainrag
